# ============================================================
# CAM-YOLO11 Environment Configuration
# Copy this file to .env and fill in the values
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Python ---
# Leave blank to auto-detect (python3 on Linux, python on Windows)
# Set explicitly if using a virtualenv: e.g. /opt/venv/bin/python
PYTHON_PATH=

# --- Model ---
# Path to your trained YOLOv11 model (.pt file)
MODEL_PATH=models/best.pt

# --- Database ---
# Path to the JSON database directory
DATABASE_PATH=./database

# --- Logs ---
LOG_DIRECTORY=./logs

# --- Detection ---
CONFIDENCE_THRESHOLD=0.70
MAX_UPLOAD_SIZE=10mb

# --- Frontend (used by Vite at build time) ---
# Set this to your Railway backend URL when deploying to Vercel
# Example: https://cam-yolo11-backend.railway.app
VITE_API_BASE_URL=

# --- CORS (set on Railway) ---
# Set to your Vercel frontend URL to restrict cross-origin access in production
# Example: https://cam-yolo11.vercel.app
CORS_ORIGIN=*

# --- Grad-CAM ---
# Toggle Grad-CAM heatmap visualization generation. 
# Set to false on low-spec/CPU-only environments (like Railway free/hobby) to avoid timeouts.
ENABLE_GRADCAM=true
